# ─────────────────────────────────────────────
# SUPABASE DATABASE
#
# Get both strings from:
#   Supabase Dashboard → Your Project → Settings → Database → Connection string
#
# DATABASE_URL  → "Transaction" pooler tab (port 6543)
#                 Used by the app at runtime — safe for Vercel serverless functions
#                 Append ?pgbouncer=true to the URL
#
# DIRECT_URL    → "Session" pooler OR the direct connection string (port 5432)
#                 Used ONLY by Prisma CLI for migrations (db push / migrate deploy)
#                 Never used by the running app
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# CLERK AUTH
# Get from: clerk.com → Your Application → API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (leave exactly as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/community
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/community

# ─────────────────────────────────────────────
# CLERK WEBHOOK
# Get from: Clerk Dashboard → Webhooks → Add endpoint → copy Signing Secret
# Endpoint URL: https://yourdomain.com/api/webhooks/clerk
# Event to subscribe: user.created
# ─────────────────────────────────────────────
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# EMAIL — Resend (admin alerts + user notifications)
# Get from: resend.com → API Keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=your@email.com

# ─────────────────────────────────────────────
# APP
# Change to your Vercel URL after deploy
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
